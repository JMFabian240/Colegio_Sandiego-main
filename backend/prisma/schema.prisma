  cicloId        Int?      @map("ciclo_id")
  actualizadoEn  DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  actualizadoPor Int?      @map("actualizado_por")

  ciclo                CicloEscolar? @relation(fields: [cicloId], references: [cicloId], onDelete: SetNull)
  actualizadoPorUsuario Usuario?     @relation("ConfigActualizadaPor", fields: [actualizadoPor], references: [usuarioId], onDelete: SetNull)

  @@unique([clave, cicloId])
  @@map("configuracion_sistema")
}

// ────────────────────────────────────────────────────────────
// BLOQUE 11: RF-06 LOGOUT — LISTA NEGRA DE TOKENS
// ────────────────────────────────────────────────────────────

model TokenRevocado {
  id         BigInt    @id @default(autoincrement())
  jti        String    @unique @db.VarChar(36)
  usuarioId  Int?      @map("usuario_id")
  revocadoEn DateTime  @default(now()) @map("revocado_en") @db.Timestamptz()
  expiraEn   DateTime  @map("expira_en") @db.Timestamptz()

  usuario Usuario? @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)

  @@map("token_revocado")
}

// ────────────────────────────────────────────────────────────
// BLOQUE 12: RF-03 PERMISOS GRANULARES POR MÓDULO
// ────────────────────────────────────────────────────────────

model UsuarioPermisoModulo {
  permisoId    Int       @id @default(autoincrement()) @map("permiso_id")
  usuarioId    Int       @map("usuario_id")
  modulo       String    @db.VarChar(30)
  nivel        String    @db.VarChar(10)
  activo       Boolean   @default(true)
  creadoEn     DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime @default(now()) @map("actualizado_en") @db.Timestamptz()

  usuario Usuario @relation(fields: [usuarioId], references: [usuarioId], onDelete: Cascade)

  @@unique([usuarioId, modulo])
  @@map("usuario_permiso_modulo")
}


