model Beca {
  becaId        Int       @id @default(autoincrement()) @map("beca_id")
  nombreBeca    String    @unique @map("nombre_beca") @db.VarChar(60)
  criterio      String    @db.VarChar(25)
  porcentaje    Decimal   @db.Decimal(5, 2)
  descripcion   String?
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn   DateTime? @map("eliminado_en") @db.Timestamptz()

  asignaciones        AsignacionBeca[]
  solicitudes         SolicitudBeca[]
  ventanasInscripcion VentanaInscripcionTemprana[]

  @@map("beca")
}

model SolicitudBeca {
  solicitudId     Int       @id @default(autoincrement()) @map("solicitud_id")
  alumnoId        Int       @map("alumno_id")
  becaId          Int       @map("beca_id")
  cicloId         Int       @map("ciclo_id")
  tipoSolicitud   String    @default("asignacion") @map("tipo_solicitud") @db.VarChar(15)
  motivo          String
  estado          String    @default("pendiente") @db.VarChar(15)
  solicitadaPor   Int?      @map("solicitada_por")
  resueltaPor     Int?      @map("resuelta_por")
  observaciones   String?
  fechaSolicitud  DateTime  @default(now()) @map("fecha_solicitud") @db.Timestamptz()
  fechaResolucion DateTime? @map("fecha_resolucion") @db.Timestamptz()
  creadoEn        DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn     DateTime? @map("eliminado_en") @db.Timestamptz()

  alumno               Alumno       @relation(fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  beca                 Beca         @relation(fields: [becaId], references: [becaId], onDelete: Restrict)
  ciclo                CicloEscolar @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  solicitadaPorUsuario Usuario?     @relation("SolicitudBecaSolicitadaPor", fields: [solicitadaPor], references: [usuarioId], onDelete: SetNull)
  resueltaPorUsuario   Usuario?     @relation("SolicitudBecaResueltaPor", fields: [resueltaPor], references: [usuarioId], onDelete: SetNull)
  asignaciones         AsignacionBeca[]

  @@map("solicitud_beca")
}

model AsignacionBeca {
  asignacionId    Int       @id @default(autoincrement()) @map("asignacion_id")
  alumnoId        Int       @map("alumno_id")
  becaId          Int       @map("beca_id")
  cicloId         Int       @map("ciclo_id")
  solicitudId     Int?      @map("solicitud_id")
  estado          String    @default("activa") @db.VarChar(15)
  fechaAsignacion DateTime  @default(now()) @map("fecha_asignacion") @db.Date
  fechaRetiro     DateTime? @map("fecha_retiro") @db.Date
  motivoRetiro    String?   @map("motivo_retiro")
  asignadaPor     Int?      @map("asignada_por")
  retiradaPor     Int?      @map("retirada_por")
  creadoEn        DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn     DateTime? @map("eliminado_en") @db.Timestamptz()

  alumno             Alumno        @relation(fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  beca               Beca          @relation(fields: [becaId], references: [becaId], onDelete: Restrict)
  ciclo              CicloEscolar  @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  solicitud          SolicitudBeca? @relation(fields: [solicitudId], references: [solicitudId], onDelete: SetNull)
  asignadaPorUsuario Usuario?      @relation("BecaAsignadaPor", fields: [asignadaPor], references: [usuarioId], onDelete: SetNull)
  retiradaPorUsuario Usuario?      @relation("BecaRetiradaPor", fields: [retiradaPor], references: [usuarioId], onDelete: SetNull)

  @@unique([alumnoId, becaId, cicloId])
  @@map("asignacion_beca")
}

model VentanaInscripcionTemprana {
  ventanaId     Int       @id @default(autoincrement()) @map("ventana_id")
  cicloId       Int       @map("ciclo_id")
  fechaInicio   DateTime  @map("fecha_inicio") @db.Date
  fechaFin      DateTime  @map("fecha_fin") @db.Date
  becaId        Int       @map("beca_id")
  activa        Boolean   @default(true)
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn   DateTime? @map("eliminado_en") @db.Timestamptz()

  ciclo CicloEscolar @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  beca  Beca         @relation(fields: [becaId], references: [becaId], onDelete: Restrict)

  @@map("ventana_inscripcion_temprana")
}

