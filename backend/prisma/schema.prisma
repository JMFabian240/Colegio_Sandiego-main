// ============================================================
// SAE Colegio San Diego — Prisma Schema v6
// Motor: PostgreSQL 16 (producción LAN y desarrollo)
// Referencia: BD-ColegioSandiego/init-db/01_esquema_base.sql v6
//
// Estrategia de compatibilidad:
//   - Nombres de tabla y columna reflejan EXACTAMENTE el SQL real
//   - Modelos Prisma en PascalCase con @map() a snake_case
//   - Relaciones nombradas explícitamente para evitar ambigüedades
//   - Soft delete: eliminado_en (no activo bool) en tablas B y C
//   - Roles: N:M via usuario_rol (no columna simple)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// BLOQUE 1: SEGURIDAD — USUARIOS Y ROLES N:M
// ────────────────────────────────────────────────────────────

model Usuario {
  usuarioId        Int       @id @default(autoincrement()) @map("usuario_id")
  nombreUsuario    String    @unique @map("nombre_usuario") @db.VarChar(80)
  nombreCompleto   String    @map("nombre_completo") @db.VarChar(120)
  correo           String?   @unique @db.VarChar(120)
  telefono         String?   @db.VarChar(15)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  activo           Boolean   @default(true)
  intentosFallidos Int       @default(0) @map("intentos_fallidos")
  bloqueadoHasta   DateTime? @map("bloqueado_hasta") @db.Timestamptz()
  ultimoAcceso     DateTime? @map("ultimo_acceso") @db.Timestamptz()
  debeCambiarPwd   Boolean   @default(false) @map("debe_cambiar_pwd")
  creadoEn         DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn      DateTime? @map("eliminado_en") @db.Timestamptz()

  // Relaciones
  roles                      UsuarioRol[]      @relation("UsuarioRoles")
  rolesAsignadosPor          UsuarioRol[]      @relation("RolesAsignadosPor")
  gruposComoTitular          Grupo[]           @relation("DocenteTitular")
  gruposMateriasDocente      GrupoMateria[]    @relation("DocenteGrupoMateria")
  configuracionesActualizadas ConfiguracionSistema[] @relation("ConfigActualizadaPor")
  pagosRegistrados           Pago[]            @relation("PagoRegistradoPor")
  calificacionesRegistradas  Calificacion[]    @relation("CalificacionRegistradaPor")
  asistenciasRegistradas     Asistencia[]      @relation("AsistenciaRegistradaPor")
  solicitudesBecaSolicitadas SolicitudBeca[]   @relation("SolicitudBecaSolicitadaPor")
  solicitudesBecaResueltas   SolicitudBeca[]   @relation("SolicitudBecaResueltaPor")
  asignacionesBecaAsignadas  AsignacionBeca[]  @relation("BecaAsignadaPor")
  asignacionesBecaRetiradas  AsignacionBeca[]  @relation("BecaRetiradaPor")
  recargoModificadoPor       Recargo[]         @relation("RecargoModificadoPor")
  documentosSubidos          Documento[]       @relation("DocumentoSubidoPor")
  facturasEmitidas           Factura[]         @relation("FacturaEmitidaPor")
  notificacionesInternas     Notificacion[]    @relation("NotificacionUsuario")
  intentosLogin              IntentoLogin[]
  logsAuditoria              LogAuditoria[]
  movimientosSaldoCreados    MovimientoSaldo[] @relation("MovimientoSaldoCreadoPor")
  calificacionesExtraRegistradas CalificacionExtracurricular[] @relation("CalificacionExtraRegistradaPor")
  calificacionesTallerRegistradas CalificacionTaller[] @relation("CalificacionTallerRegistradaPor")
  // RF-06: tokens revocados por logout
  tokensRevocados            TokenRevocado[]
  // RF-03: permisos granulares por módulo
  permisosModulos            UsuarioPermisoModulo[]

  @@map("usuario")
}

model Rol {
  rolId         Int       @id @default(autoincrement()) @map("rol_id")
  codigo        String    @unique @db.VarChar(20)
  nombre        String    @db.VarChar(60)
  descripcion   String?
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn   DateTime? @map("eliminado_en") @db.Timestamptz()

  usuarios UsuarioRol[]

  @@map("rol")
}

model UsuarioRol {
  usuarioRolId  Int       @id @default(autoincrement()) @map("usuario_rol_id")
  usuarioId     Int       @map("usuario_id")
  rolId         Int       @map("rol_id")
  asignadoEn    DateTime  @default(now()) @map("asignado_en") @db.Timestamptz()
  asignadoPor   Int?      @map("asignado_por")
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn   DateTime? @map("eliminado_en") @db.Timestamptz()

  usuario            Usuario  @relation("UsuarioRoles", fields: [usuarioId], references: [usuarioId], onDelete: Cascade)
  rol                Rol      @relation(fields: [rolId], references: [rolId], onDelete: Restrict)
  asignadoPorUsuario Usuario? @relation("RolesAsignadosPor", fields: [asignadoPor], references: [usuarioId], onDelete: SetNull)

  @@unique([usuarioId, rolId])
  @@map("usuario_rol")
}

// ────────────────────────────────────────────────────────────
// BLOQUE 2: CATÁLOGOS Y CICLO
// ────────────────────────────────────────────────────────────

model NivelEducativo {
  nivelId       Int       @id @default(autoincrement()) @map("nivel_id")
  codigo        String    @unique @db.VarChar(15)
  nombre        String    @db.VarChar(60)
  rvoe          String?   @db.VarChar(40)
  orden         Int
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn   DateTime? @map("eliminado_en") @db.Timestamptz()

  grupos             Grupo[]
  materias           Materia[]
  periodosEvaluacion PeriodoEvaluacion[]
  alumnos            Alumno[]
  tarifas            Tarifa[]

  @@map("nivel_educativo")
}

model CicloEscolar {
  cicloId       Int       @id @default(autoincrement()) @map("ciclo_id")
  nombre        String    @unique @db.VarChar(20)
  fechaInicio   DateTime  @map("fecha_inicio") @db.Date
  fechaFin      DateTime  @map("fecha_fin") @db.Date
  activo        Boolean   @default(false)
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn   DateTime? @map("eliminado_en") @db.Timestamptz()

  grupos                    Grupo[]
  periodosEvaluacion        PeriodoEvaluacion[]
  planesPago                PlanPago[]
  inscripciones             InscripcionCiclo[]
  tarifas                   Tarifa[]
  calendariosPago           CalendarioPago[]
  asignacionesBeca          AsignacionBeca[]
  solicitudesBeca           SolicitudBeca[]
  ventanasInscripcion       VentanaInscripcionTemprana[]
  configuraciones           ConfiguracionSistema[]
  calificacionesExtra       CalificacionExtracurricular[]
  calificacionesTaller      CalificacionTaller[]

  @@map("ciclo_escolar")
}

// ────────────────────────────────────────────────────────────
// BLOQUE 3: ESTRUCTURA ACADÉMICA
// ────────────────────────────────────────────────────────────

model Grupo {
  grupoId          Int       @id @default(autoincrement()) @map("grupo_id")
  cicloId          Int       @map("ciclo_id")
  nivelId          Int       @map("nivel_id")
  grado            String    @db.VarChar(10)
  seccion          String    @db.VarChar(5)
  nombre           String    @db.VarChar(60)
  docenteTitularId Int?      @map("docente_titular_id")
  cupoMaximo       Int?      @map("cupo_maximo")
  creadoEn         DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn      DateTime? @map("eliminado_en") @db.Timestamptz()

  ciclo          CicloEscolar   @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  nivel          NivelEducativo @relation(fields: [nivelId], references: [nivelId], onDelete: Restrict)
  docenteTitular Usuario?       @relation("DocenteTitular", fields: [docenteTitularId], references: [usuarioId], onDelete: SetNull)
  gruposMaterias GrupoMateria[]
  inscripciones  InscripcionCiclo[]

  @@unique([cicloId, nivelId, grado, seccion])
  @@map("grupo")
}

model Materia {
  materiaId          Int       @id @default(autoincrement()) @map("materia_id")
  nivelId            Int       @map("nivel_id")
  claveSep           String?   @map("clave_sep") @db.VarChar(20)
  nombre             String    @db.VarChar(80)
  descripcion        String?
  horasSemanales     Int?      @map("horas_semanales")
  creditos           Decimal?  @db.Decimal(4, 1)
  tipo               String    @default("curricular") @db.VarChar(15)
  cuentaParaPromedio Boolean   @default(true) @map("cuenta_para_promedio")
  creadoEn           DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn      DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn        DateTime? @map("eliminado_en") @db.Timestamptz()

  nivel          NivelEducativo @relation(fields: [nivelId], references: [nivelId], onDelete: Restrict)
  gruposMaterias GrupoMateria[]

  @@unique([nivelId, nombre, tipo])
  @@map("materia")
}

model GrupoMateria {
  grupoMateriaId Int       @id @default(autoincrement()) @map("grupo_materia_id")
  grupoId        Int       @map("grupo_id")
  materiaId      Int       @map("materia_id")
  docenteId      Int?      @map("docente_id")
  horario        String?   @db.VarChar(80)
  aula           String?   @db.VarChar(40)
  creadoEn       DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn  DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn    DateTime? @map("eliminado_en") @db.Timestamptz()

  grupo          Grupo    @relation(fields: [grupoId], references: [grupoId], onDelete: Restrict)
  materia        Materia  @relation(fields: [materiaId], references: [materiaId], onDelete: Restrict)
  docente        Usuario? @relation("DocenteGrupoMateria", fields: [docenteId], references: [usuarioId], onDelete: SetNull)
  calificaciones Calificacion[]
  asistencias    Asistencia[]
  inscripcionesMateria InscripcionMateria[]

  @@unique([grupoId, materiaId])
  @@map("grupo_materia")
}

model InscripcionMateria {
  inscripcionId  Int      @id @default(autoincrement()) @map("inscripcion_materia_id")
  alumnoId       Int      @map("alumno_id")
  grupoMateriaId Int      @map("grupo_materia_id")
  creadoEn       DateTime @default(now()) @map("creado_en") @db.Timestamptz(6)

  alumno       Alumno       @relation(fields: [alumnoId], references: [alumnoId], onDelete: Cascade)
  grupoMateria GrupoMateria @relation(fields: [grupoMateriaId], references: [grupoMateriaId], onDelete: Cascade)

  @@unique([alumnoId, grupoMateriaId])
  @@map("inscripcion_materia")
}

model PeriodoEvaluacion {
  periodoId     Int       @id @default(autoincrement()) @map("periodo_id")
  cicloId       Int       @map("ciclo_id")
  nivelId       Int       @map("nivel_id")
  tipo          String    @db.VarChar(15)
  numero        Int
  nombre        String    @db.VarChar(40)
  fechaInicio   DateTime  @map("fecha_inicio") @db.Date
  fechaFin      DateTime  @map("fecha_fin") @db.Date
  esFinalCiclo  Boolean   @default(false) @map("es_final_ciclo")
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn   DateTime? @map("eliminado_en") @db.Timestamptz()

  ciclo          CicloEscolar   @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  nivel          NivelEducativo @relation(fields: [nivelId], references: [nivelId], onDelete: Restrict)
  calificaciones Calificacion[]
  calificacionesExtra CalificacionExtracurricular[]
  calificacionesTaller CalificacionTaller[]

  @@unique([cicloId, nivelId, tipo, numero])
  @@map("periodo_evaluacion")
}

// ────────────────────────────────────────────────────────────
// BLOQUE 4: COMUNIDAD ESCOLAR
// ────────────────────────────────────────────────────────────

model Tutor {
  tutorId            Int       @id @default(autoincrement()) @map("tutor_id")
  nombreCompleto     String    @map("nombre_completo") @db.VarChar(120)
  correoElectronico  String?   @map("correo_electronico") @db.VarChar(120)
  telefono           String?   @db.VarChar(15)
  direccion          String?
  rfc                String?   @unique @db.VarChar(13)
  curp               String?   @db.VarChar(18)
  regimenFiscal      String?   @map("regimen_fiscal") @db.VarChar(10)
  usoCfdi            String?   @map("uso_cfdi") @db.VarChar(10)
  direccionFiscal    String?   @map("direccion_fiscal")
  codigoPostal       String?   @map("codigo_postal") @db.VarChar(10)
  correoFacturacion  String?   @map("correo_facturacion") @db.VarChar(120)
  requiereFactura    Boolean   @default(false) @map("requiere_factura")
  tipoPagoHabitual   String?   @map("tipo_pago_habitual") @db.VarChar(15)
  saldoAFavor        Decimal   @default(0) @map("saldo_a_favor") @db.Decimal(12, 2)
  activo             Boolean   @default(true)
  creadoEn           DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn      DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn        DateTime? @map("eliminado_en") @db.Timestamptz()

  alumnos          TutorAlumno[]
  pagos            Pago[]
  movimientosSaldo MovimientoSaldo[]
  facturas         Factura[]
  documentos       Documento[]     @relation("DocumentoTutor")
  notificaciones   Notificacion[]  @relation("NotificacionTutor")

  @@map("tutor")
}

model Alumno {
  alumnoId              Int       @id @default(autoincrement()) @map("alumno_id")
  matricula             String    @unique @db.VarChar(30)
  curp                  String?   @unique @db.VarChar(18)
  nombreCompleto        String    @map("nombre_completo") @db.VarChar(120)
  fechaNacimiento       DateTime? @map("fecha_nacimiento") @db.Date
  sexo                  String?   @db.Char(1)
  nivelId               Int?      @map("nivel_id")
  estado                String    @default("Activo") @db.VarChar(20)
  fechaBaja             DateTime? @map("fecha_baja") @db.Date
  motivoBaja            String?   @map("motivo_baja")
  diaLimitePago         Int?      @map("dia_limite_pago")
  personasAutorizadas   Json      @default("[]") @map("personas_autorizadas")
  observaciones         String?
  creadoEn              DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn           DateTime? @map("eliminado_en") @db.Timestamptz()

  nivel            NivelEducativo?  @relation(fields: [nivelId], references: [nivelId], onDelete: Restrict)
  tutores          TutorAlumno[]
  inscripciones    InscripcionCiclo[]
  calificaciones   Calificacion[]
  calificacionesExtra CalificacionExtracurricular[]
  calificacionesTaller CalificacionTaller[]
  asistencias      Asistencia[]
  calendariosPago  CalendarioPago[]
  pagos            Pago[]           @relation("PagoAlumno")
  asignacionesBeca AsignacionBeca[]
  solicitudesBeca  SolicitudBeca[]
  documentos       Documento[]      @relation("DocumentoAlumno")
  notificaciones   Notificacion[]   @relation("NotificacionAlumno")
  inscripcionesMateria InscripcionMateria[]

  @@map("alumno")
}

model TutorAlumno {
  tutorAlumnoId           Int       @id @default(autoincrement()) @map("tutor_alumno_id")
  tutorId                 Int       @map("tutor_id")
  alumnoId                Int       @map("alumno_id")
  tipoRelacion            String    @default("tutor") @map("tipo_relacion") @db.VarChar(15)
  esResponsableFinanciero Boolean   @default(false) @map("es_responsable_financiero")
  puedeRecoger            Boolean   @default(true) @map("puede_recoger")
  recibeNotificaciones    Boolean   @default(true) @map("recibe_notificaciones")
  activo                  Boolean   @default(true)
  creadoEn                DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn           DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn             DateTime? @map("eliminado_en") @db.Timestamptz()

  tutor  Tutor  @relation(fields: [tutorId], references: [tutorId], onDelete: Cascade)
  alumno Alumno @relation(fields: [alumnoId], references: [alumnoId], onDelete: Cascade)

  @@unique([tutorId, alumnoId])
  @@map("tutor_alumno")
}

// ────────────────────────────────────────────────────────────
// BLOQUE 5: PLAN DE PAGO E INSCRIPCIÓN
// ────────────────────────────────────────────────────────────

model PlanPago {
  planPagoId     Int       @id @default(autoincrement()) @map("plan_pago_id")
  cicloId        Int       @map("ciclo_id")
  nombre         String    @db.VarChar(40)
  meses          Int
  montoMensual   Decimal   @map("monto_mensual") @db.Decimal(12, 2)
  montoDiciembre Decimal   @map("monto_diciembre") @db.Decimal(12, 2)
  descripcion    String?
  activo         Boolean   @default(true)
  creadoEn       DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn  DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn    DateTime? @map("eliminado_en") @db.Timestamptz()

  ciclo         CicloEscolar     @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  inscripciones InscripcionCiclo[]

  @@unique([cicloId, nombre])
  @@map("plan_pago")
}

model InscripcionCiclo {
  inscripcionId    Int       @id @default(autoincrement()) @map("inscripcion_id")
  alumnoId         Int       @map("alumno_id")
  cicloId          Int       @map("ciclo_id")
  grupoId          Int       @map("grupo_id")
  /// @deprecated desde v6 — usar plan_pago_id
  planPago         String    @default("10_meses") @map("plan_pago") @db.VarChar(10)
  planPagoId       Int?      @map("plan_pago_id")
  fechaIngreso     DateTime  @default(now()) @map("fecha_ingreso") @db.Date
  esIngresoTardio  Boolean   @default(false) @map("es_ingreso_tardio")
  estadoEnCiclo    String    @default("activa") @map("estado_en_ciclo") @db.VarChar(20)
  estadoFinanciero String    @default("al_corriente") @map("estado_financiero") @db.VarChar(20)
  mesesAdeudo      Int       @default(0) @map("meses_adeudo")
  motivoBaja       String?   @map("motivo_baja")
  fechaBaja        DateTime? @map("fecha_baja") @db.Date
  creadoEn         DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn      DateTime? @map("eliminado_en") @db.Timestamptz()

  alumno    Alumno        @relation(fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  ciclo     CicloEscolar  @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  grupo     Grupo         @relation(fields: [grupoId], references: [grupoId], onDelete: Restrict)
  planDepago PlanPago?    @relation(fields: [planPagoId], references: [planPagoId], onDelete: Restrict)

  @@unique([alumnoId, cicloId])
  @@map("inscripcion_ciclo")
}

// ────────────────────────────────────────────────────────────
// BLOQUE 6: CALIFICACIONES Y ASISTENCIA
// ────────────────────────────────────────────────────────────

model Calificacion {
  calificacionId     Int       @id @default(autoincrement()) @map("calificacion_id")
  alumnoId           Int       @map("alumno_id")
  grupoMateriaId     Int       @map("grupo_materia_id")
  periodoId          Int       @map("periodo_id")
  tipoEvaluacion     String    @default("numerica") @map("tipo_evaluacion") @db.VarChar(15)
  valorNumerico      Decimal?  @map("valor_numerico") @db.Decimal(4, 2)
  valorCualitativo   String?   @map("valor_cualitativo") @db.VarChar(5)
  textoObservacion   String?   @map("texto_observacion")
  cuentaParaPromedio Boolean   @default(true) @map("cuenta_para_promedio")
  modificadaMotivo   String?   @map("modificada_motivo")
  registradaPor      Int?      @map("registrada_por")
  registradaEn       DateTime  @default(now()) @map("registrada_en") @db.Timestamptz()
  actualizadoEn      DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  alumno       Alumno            @relation(fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  grupoMateria GrupoMateria      @relation(fields: [grupoMateriaId], references: [grupoMateriaId], onDelete: Restrict)
  periodo      PeriodoEvaluacion @relation(fields: [periodoId], references: [periodoId], onDelete: Restrict)
  registradoPorUsuario Usuario?  @relation("CalificacionRegistradaPor", fields: [registradaPor], references: [usuarioId], onDelete: SetNull)

  @@unique([alumnoId, grupoMateriaId, periodoId])
  @@map("calificacion")
}

model CalificacionExtracurricular {
  calificacionExtracurricularId Int       @id @default(autoincrement()) @map("calificacion_extracurricular_id")
  alumnoId           Int       @map("alumno_id")
  club               String    @db.VarChar(50) // "ingles", "computacion", "danza"
  periodoId          Int       @map("periodo_id")
  cicloId            Int       @map("ciclo_id")
  valorNumerico      Decimal?  @map("valor_numerico") @db.Decimal(4, 2)
  modificadaMotivo   String?   @map("modificada_motivo")
  registradaPor      Int?      @map("registrada_por")
  registradaEn       DateTime  @default(now()) @map("registrada_en") @db.Timestamptz()
  actualizadoEn      DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  alumno             Alumno            @relation(fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  periodo            PeriodoEvaluacion @relation(fields: [periodoId], references: [periodoId], onDelete: Restrict)
  ciclo              CicloEscolar      @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
