// BLOQUE 7: FINANZAS
// ────────────────────────────────────────────────────────────

model Tarifa {
  tarifaId      Int       @id @default(autoincrement()) @map("tarifa_id")
  cicloId       Int       @map("ciclo_id")
  nivelId       Int       @map("nivel_id")
  concepto      String    @db.VarChar(15)
  monto         Decimal   @db.Decimal(12, 2)
  descripcion   String?
  activa        Boolean   @default(true)
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn   DateTime? @map("eliminado_en") @db.Timestamptz()

  ciclo CicloEscolar   @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  nivel NivelEducativo @relation(fields: [nivelId], references: [nivelId], onDelete: Restrict)

  @@unique([cicloId, nivelId, concepto])
  @@map("tarifa")
}

model CalendarioPago {
  calendarioPagoId Int       @id @default(autoincrement()) @map("calendario_pago_id")
  alumnoId         Int       @map("alumno_id")
  cicloId          Int       @map("ciclo_id")
  concepto         String    @db.VarChar(15)
  mes              String?   @db.VarChar(15)
  fechaVencimiento DateTime  @map("fecha_vencimiento") @db.Date
  montoOriginal    Decimal   @map("monto_original") @db.Decimal(12, 2)
  montoPagado      Decimal   @default(0) @map("monto_pagado") @db.Decimal(12, 2)
  montoRecargo     Decimal   @default(0) @map("monto_recargo") @db.Decimal(12, 2)
  // GENERATED ALWAYS AS (monto_original + monto_recargo - monto_pagado) STORED
  saldoPendiente   Decimal   @default(dbgenerated("(monto_original + monto_recargo - monto_pagado)")) @map("saldo_pendiente") @db.Decimal(12, 2)
  estadoCobro      String    @default("pendiente") @map("estado_cobro") @db.VarChar(15)
  liquidadoAt      DateTime? @map("liquidado_at") @db.Timestamptz()
  creadoEn         DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn      DateTime? @map("eliminado_en") @db.Timestamptz()

  alumno         Alumno           @relation(fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  ciclo          CicloEscolar     @relation(fields: [cicloId], references: [cicloId], onDelete: Restrict)
  aplicaciones   AplicacionPago[]
  recargos       Recargo[]
  notificaciones Notificacion[]

  @@unique([alumnoId, cicloId, concepto, mes])
  @@map("calendario_pago")
}

model Pago {
  pagoId         Int       @id @default(autoincrement()) @map("pago_id")
  alumnoId       Int?      @map("alumno_id")
  tutorId        Int?      @map("tutor_id")
  fechaPago      DateTime  @default(now()) @map("fecha_pago") @db.Date
  montoTotal     Decimal   @map("monto_total") @db.Decimal(12, 2)
  metodoPago     String    @map("metodo_pago") @db.VarChar(15)
  aplicadoASaldo Boolean   @default(false) @map("aplicado_a_saldo")
  observaciones  String?
  registradoPor  Int?      @map("registrado_por")
  registradoEn   DateTime  @default(now()) @map("registrado_en") @db.Timestamptz()
  actualizadoEn  DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  alumno               Alumno?   @relation("PagoAlumno", fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  tutor                Tutor?    @relation(fields: [tutorId], references: [tutorId], onDelete: Restrict)
  registradoPorUsuario Usuario?  @relation("PagoRegistradoPor", fields: [registradoPor], references: [usuarioId], onDelete: SetNull)
  aplicaciones         AplicacionPago[]
  movimientosSaldo     MovimientoSaldo[]
  documentos           Documento[]  @relation("DocumentoPago")
  facturasPago         FacturaPago[]

  @@map("pago")
}

model AplicacionPago {
  aplicacionId     Int       @id @default(autoincrement()) @map("aplicacion_id")
  pagoId           Int       @map("pago_id")
  calendarioPagoId Int       @map("calendario_pago_id")
  montoAplicado    Decimal   @map("monto_aplicado") @db.Decimal(12, 2)
  aplicadoA        String    @default("capital") @map("aplicado_a") @db.VarChar(15)
  creadoEn         DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  pago             Pago           @relation(fields: [pagoId], references: [pagoId], onDelete: Cascade)
  calendarioPago   CalendarioPago @relation(fields: [calendarioPagoId], references: [calendarioPagoId], onDelete: Restrict)
  movimientosSaldo MovimientoSaldo[]

  @@unique([pagoId, calendarioPagoId, aplicadoA])
  @@map("aplicacion_pago")
}

model Recargo {
  recargoId          Int       @id @default(autoincrement()) @map("recargo_id")
  calendarioPagoId   Int       @map("calendario_pago_id")
  montoOriginal      Decimal   @map("monto_original") @db.Decimal(12, 2)
  montoActual        Decimal   @map("monto_actual") @db.Decimal(12, 2)
  estado             String    @default("aplicado") @db.VarChar(15)
  motivoModificacion String?   @map("motivo_modificacion")
  aplicadoEn         DateTime  @default(now()) @map("aplicado_en") @db.Date
  modificadoPor      Int?      @map("modificado_por")
  modificadoEn       DateTime? @map("modificado_en") @db.Timestamptz()
  actualizadoEn      DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  calendarioPago       CalendarioPago @relation(fields: [calendarioPagoId], references: [calendarioPagoId], onDelete: Cascade)
  modificadoPorUsuario Usuario?       @relation("RecargoModificadoPor", fields: [modificadoPor], references: [usuarioId], onDelete: SetNull)

  @@map("recargo")
}

model MovimientoSaldo {
  movimientoId  Int       @id @default(autoincrement()) @map("movimiento_id")
  tutorId       Int       @map("tutor_id")
  tipo          String    @db.VarChar(15)
  monto         Decimal   @db.Decimal(12, 2)
  pagoId        Int?      @map("pago_id")
  aplicacionId  Int?      @map("aplicacion_id")
  descripcion   String?
  creadoPor     Int?      @map("creado_por")
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  tutor      Tutor           @relation(fields: [tutorId], references: [tutorId], onDelete: Cascade)
  pago       Pago?           @relation(fields: [pagoId], references: [pagoId], onDelete: Restrict)
  aplicacion AplicacionPago? @relation(fields: [aplicacionId], references: [aplicacionId], onDelete: Restrict)
  creadoPorUsuario Usuario?  @relation("MovimientoSaldoCreadoPor", fields: [creadoPor], references: [usuarioId], onDelete: SetNull)

  @@map("movimiento_saldo")
}

model Factura {
  facturaId             Int       @id @default(autoincrement()) @map("factura_id")
  tutorId               Int       @map("tutor_id")
  numeroFactura         String?   @unique @map("numero_factura") @db.VarChar(40)
  uuidSat               String?   @map("uuid_sat") @db.Uuid
  fechaEmision          DateTime  @default(now()) @map("fecha_emision") @db.Date
  montoTotal            Decimal   @map("monto_total") @db.Decimal(12, 2)
  receptorRfc           String    @map("receptor_rfc") @db.VarChar(13)
  receptorRazonSocial   String    @map("receptor_razon_social") @db.VarChar(255)
  receptorCodigoPostal  String    @map("receptor_codigo_postal") @db.VarChar(10)
  receptorDireccion     String    @map("receptor_direccion")
  receptorCorreo        String    @map("receptor_correo")
  receptorRegimenFiscal String    @map("receptor_regimen_fiscal") @db.VarChar(10)
  usoCfdi               String?   @map("uso_cfdi") @db.VarChar(10)
  metodoPagoSat         String?   @map("metodo_pago_sat") @db.VarChar(10)
  formaPagoSat          String?   @map("forma_pago_sat") @db.VarChar(10)
  estado                String    @default("emitida") @db.VarChar(15)
  xmlDocumentoId        Int?      @map("xml_documento_id")
  pdfDocumentoId        Int?      @map("pdf_documento_id")
  emitidaPor            Int?      @map("emitida_por")
  creadaEn              DateTime  @default(now()) @map("creada_en") @db.Timestamptz()
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  tutor             Tutor    @relation(fields: [tutorId], references: [tutorId], onDelete: Restrict)
  emitidaPorUsuario Usuario? @relation("FacturaEmitidaPor", fields: [emitidaPor], references: [usuarioId], onDelete: SetNull)
  xmlDocumento      Documento? @relation("FacturaXml", fields: [xmlDocumentoId], references: [documentoId], onDelete: SetNull)
  pdfDocumento      Documento? @relation("FacturaPdf", fields: [pdfDocumentoId], references: [documentoId], onDelete: SetNull)
  pagos             FacturaPago[]
  documentos        Documento[] @relation("DocumentoFactura")

  @@map("factura")
}

model FacturaPago {
  facturaId     Int       @map("factura_id")
  pagoId        Int       @map("pago_id")
  monto         Decimal   @db.Decimal(12, 2)
  creadoEn      DateTime  @default(now()) @map("creado_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  factura Factura @relation(fields: [facturaId], references: [facturaId], onDelete: Cascade)
  pago    Pago    @relation(fields: [pagoId], references: [pagoId], onDelete: Restrict)

  @@id([facturaId, pagoId])
  @@map("factura_pago")
}

