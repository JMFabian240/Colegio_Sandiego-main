model Documento {
  documentoId   Int       @id @default(autoincrement()) @map("documento_id")
  tipoDocumento String    @map("tipo_documento") @db.VarChar(25)
  nombreOriginal String   @map("nombre_original") @db.VarChar(255)
  rutaAlmacen   String    @map("ruta_almacen")
  mimeType      String    @map("mime_type") @db.VarChar(100)
  tamanoBytes   BigInt    @map("tamano_bytes")
  hashSha256    String?   @map("hash_sha256") @db.Char(64)
  alumnoId      Int?      @map("alumno_id")
  tutorId       Int?      @map("tutor_id")
  pagoId        Int?      @map("pago_id")
  facturaId     Int?      @map("factura_id")
  subidoPor     Int?      @map("subido_por")
  subidoEn      DateTime  @default(now()) @map("subido_en") @db.Timestamptz()
  actualizadoEn DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()

  alumno           Alumno?   @relation("DocumentoAlumno", fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  tutor            Tutor?    @relation("DocumentoTutor", fields: [tutorId], references: [tutorId], onDelete: Restrict)
  pago             Pago?     @relation("DocumentoPago", fields: [pagoId], references: [pagoId], onDelete: Restrict)
  factura          Factura?  @relation("DocumentoFactura", fields: [facturaId], references: [facturaId], onDelete: Restrict)
  subidoPorUsuario Usuario?  @relation("DocumentoSubidoPor", fields: [subidoPor], references: [usuarioId], onDelete: SetNull)
  // Circular: factura puede referenciar este documento como xml o pdf
  facturaComoXml   Factura[] @relation("FacturaXml")
  facturaComoPdf   Factura[] @relation("FacturaPdf")

  @@map("documento")
}

model Notificacion {
  notificacionId        Int       @id @default(autoincrement()) @map("notificacion_id")
  tipo                  String    @db.VarChar(30)
  canal                 String    @default("email") @db.VarChar(10)
  destinatarioTutorId   Int?      @map("destinatario_tutor_id")
  destinatarioEmail     String?   @map("destinatario_email")
  destinatarioUsuarioId Int?      @map("destinatario_usuario_id")
  asunto                String?   @db.VarChar(160)
  cuerpo                String?
  estado                String    @default("pendiente") @db.VarChar(15)
  intentos              Int       @default(0)
  errorUltimo           String?   @map("error_ultimo")
  programadaPara        DateTime? @map("programada_para") @db.Timestamptz()
  enviadaEn             DateTime? @map("enviada_en") @db.Timestamptz()
  alumnoId              Int?      @map("alumno_id")
  calendarioPagoId      Int?      @map("calendario_pago_id")
  creadaEn              DateTime  @default(now()) @map("creada_en") @db.Timestamptz()
  actualizadoEn         DateTime  @updatedAt @map("actualizado_en") @db.Timestamptz()
  eliminadoEn           DateTime? @map("eliminado_en") @db.Timestamptz()

  tutor          Tutor?          @relation("NotificacionTutor", fields: [destinatarioTutorId], references: [tutorId], onDelete: Cascade)
  usuario        Usuario?        @relation("NotificacionUsuario", fields: [destinatarioUsuarioId], references: [usuarioId], onDelete: Cascade)
  alumno         Alumno?         @relation("NotificacionAlumno", fields: [alumnoId], references: [alumnoId], onDelete: Restrict)
  calendarioPago CalendarioPago? @relation(fields: [calendarioPagoId], references: [calendarioPagoId], onDelete: Restrict)

  @@map("notificacion")
}

